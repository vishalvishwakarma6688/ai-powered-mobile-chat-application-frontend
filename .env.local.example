# API Configuration
# Copy this file to .env.local and update with your machine's IP address

# For Physical Device Testing:
# Find your IP address:
# - Windows: Run `ipconfig` and look for "IPv4 Address" under your active network adapter
# - Mac/Linux: Run `ifconfig` or `ip addr` and look for your local IP
# - Example: EXPO_PUBLIC_API_URL=http://192.168.1.10:5000

# For Android Emulator (default):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# For iOS Simulator (default):
# EXPO_PUBLIC_API_URL=http://localhost:5000

# Your machine's IP (update this):
EXPO_PUBLIC_API_URL=http://10.41.123.26:5000
